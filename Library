    -- Function to show a specific tab content
    local function showTabContent(tabName)
        for _, tab in pairs(window.tabs) do
            if tab.contentFrame then
                tab.contentFrame.Visible = false
            end
            if tab.button and tab.button:FindFirstChild("Highlight") then
                tab.button.Highlight.Visible = false
            end
        end
        
        if window.tabs[tabName] and window.tabs[tabName].contentFrame then
            window.tabs[tabName].contentFrame.Visible = true
            if window.tabs[tabName].button and window.tabs[tabName].button:FindFirstChild("Highlight") then
                window.tabs[tabName].button.Highlight.Visible = true
            end
            window.currentTab = tabName
        end
    end
    
    -- Add tab method
    function window:AddTab(name)
        local tab = {}
        tab.name = name
        tab.button = createTabButton(name, 50 + (#window.tabs * 40))
        tab.contentFrame = createTabContent(name)
        tab.elements = {}
        
        window.tabs[name] = tab
        
        -- Connect tab button to show its content
        tab.button.MouseButton1Click:Connect(function()
            showTabContent(name)
        end)
        
        -- Show first tab by default
        if #window.tabs == 1 then
            showTabContent(name)
        end
        
