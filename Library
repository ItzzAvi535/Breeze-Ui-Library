    function window:ShowTab(tabName)
        for _, tab in pairs(window.Tabs) do
            tab.ContentFrame.Visible = false
            local tabButton = MainFrame:FindFirstChild(tab.Name)
            if tabButton and tabButton:FindFirstChild("Highlight") then
                tabButton.Highlight.Visible = false
            end
        end
        for _, tab in pairs(window.Tabs) do
            if tab.Name == tabName then
                tab.ContentFrame.Visible = true
                window.ActiveTab = tab
                local tabButton = MainFrame:FindFirstChild(tabName)
                if tabButton and tabButton:FindFirstChild("Highlight") then
                    tabButton.Highlight.Visible = true
                end
            end
        end
    end
    
    return window
