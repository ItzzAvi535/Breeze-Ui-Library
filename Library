    SearchBox.FocusLost:Connect(function(enterPressed)
        if enterPressed then
            local searchText = string.lower(SearchBox.Text)
            if searchText == "" then return end
            for _, tab in pairs(window.Tabs) do
                for _, container in pairs(tab.ContentFrame:GetChildren()) do
                    if container:IsA("Frame") then
                        local textElements = {
                            container:FindFirstChild("TitleLabel"),
                            container:FindFirstChild("ToggleLabel"),
                            container:FindFirstChild("LabelText"),
                            container:FindFirstChild("DropdownTitle"),
                            container:FindFirstChild("SliderLabel"),
                            container:FindFirstChild("InputBox"),
                            container:FindFirstChild("ValueLabel")
                        }
                        local actionButton = container:FindFirstChild("ActionButton")
                        if actionButton and actionButton:IsA("TextButton") then
                            table.insert(textElements, actionButton)
                        end
                        local dropdownButton = container:FindFirstChild("DropdownButton")
                        if dropdownButton and dropdownButton:IsA("TextButton") then
                            table.insert(textElements, dropdownButton)
                        end
                        for _, textElement in pairs(textElements) do
                            if textElement and textElement:IsA("GuiObject") and textElement.Text then
                                local elementText = string.lower(textElement.Text)
                                if string.find(elementText, searchText) then
                                    window:ShowTab(tab.Name)
                                    local originalColor = container.BackgroundColor3
                                    container.BackgroundColor3 = window.main_color
                                    tab.ContentFrame.CanvasPosition = Vector2.new(0, container.Position.Y.Offset - 20)
                                    task.delay(3, function()
                                        if container and container.Parent then
                                            container.BackgroundColor3 = originalColor
                                        end
                                    end)
                                    window:CreateNotification("Found: " .. textElement.Text)
                                    return
                                end
                            end
                        end
                        local inputBox = container:FindFirstChild("InputBox")
                        if inputBox and inputBox:IsA("TextBox") and inputBox.PlaceholderText then
                            local placeholderText = string.lower(inputBox.PlaceholderText)
                            if string.find(placeholderText, searchText) then
                                window:ShowTab(tab.Name)
                                local originalColor = container.BackgroundColor3
                                container.BackgroundColor3 = window.main_color
                                tab.ContentFrame.CanvasPosition = Vector2.new(0, container.Position.Y.Offset - 20)
                                task.delay(3, function()
                                    if container and container.Parent then
                                        container.BackgroundColor3 = originalColor
                                    end
                                end)
                                window:CreateNotification("Found in placeholder: " .. inputBox.PlaceholderText)
                                return
                            end
                        end
                    end
                end
            end
            window:CreateNotification("No results found for: " .. searchText)
        end
    end)
    
    if window.key_system then
        ValidateButton.MouseButton1Click:Connect(function()
            local enteredKey = KeyInput.Text
            local isValid = false
            for _, key in pairs(window.keys.Free) do
                if enteredKey == key then
                    isValid = true
                    break
                end
            end
            for _, key in pairs(window.keys.Premium) do
                if enteredKey == key then
                    isValid = true
                    break
                end
            end
            if isValid then
                StatusLabel.Text = "Key Validated Successfully!"
                StatusLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
                local successTween = TweenService:Create(KeyMainFrame, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(0, 30, 0)})
                successTween:Play()
                successTween.Completed:Wait()
                TweenService:Create(KeyMainFrame, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(10, 10, 15)}):Play()
                local hideTween = TweenService:Create(KeyMainFrame, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
                    Size = UDim2.new(0, 0, 0, 0),
                    Position = UDim2.new(0.5, 0, 0.5, 0)
