local Breeze = {}
local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")

-- helper
local function new(inst, props)
    local obj = Instance.new(inst)
    for k, v in pairs(props) do
        obj[k] = v
    end
    return obj
end

function Breeze:CreateWindow(title, opts)
    opts = opts or {}
    local size = opts.size or UDim2.new(0, 580, 0, 400)
    local player = Players.LocalPlayer
    local gui = player:WaitForChild("PlayerGui")

    -- screen
    local screenGui = new("ScreenGui", {
        Name = "Breeze",
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
        Parent = gui
    })

    -- frame
    local frame = new("Frame", {
        Name = "MainFrame",
        Size = size,
        Position = UDim2.new(0.5, 0, 0.5, 0),
        AnchorPoint = Vector2.new(0.5, 0.5),
        BackgroundColor3 = Color3.fromRGB(30, 30, 30),
        BackgroundTransparency = 0.4,
        BorderSizePixel = 0,
        Parent = screenGui,
        Active = true,
        Draggable = true
    })

    local uiCorner = new("UICorner", {CornerRadius = UDim.new(0, 8), Parent = frame})

    local titleLabel = new("TextLabel", {
        Name = "Title",
        Size = UDim2.new(1, 0, 0, 40),
        BackgroundTransparency = 1,
        Text = title or "Breeze UI",
        TextColor3 = Color3.fromRGB(255, 255, 255),
        TextSize = 18,
        Font = Enum.Font.GothamBold,
        Parent = frame,
        ZIndex = 2
    })

    local separator = new("Frame", {
        Name = "Separator",
        Size = UDim2.new(1, -20, 0, 1),
        Position = UDim2.new(0, 10, 0, 40),
        BackgroundColor3 = Color3.fromRGB(255, 255, 255),
        BackgroundTransparency = 0.8,
        BorderSizePixel = 0,
        Parent = frame,
        ZIndex = 2
    })

    local tabButtonContainer = new("Frame", {
        Name = "TabButtonContainer",
        Size = UDim2.new(0, 150, 1, -50),
        Position = UDim2.new(0, 10, 0, 50),
        BackgroundTransparency = 1,
        Parent = frame,
        ZIndex = 3
    })

    local listLayout = new("UIListLayout", {
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding = UDim.new(0, 5),
        Parent = tabButtonContainer
    })

    local activeTab

    local api = {}

    function api:CreateTab(tabName)
        local tabButton = new("TextButton", {
            Name = tabName .. "Tab",
            Size = UDim2.new(1, -10, 0, 40),
            BackgroundColor3 = Color3.fromRGB(30, 30, 30),
            BackgroundTransparency = 0.7,
            BorderSizePixel = 0,
            Text = "",
            Parent = tabButtonContainer,
            ZIndex = 3
        })

        local tabCorner = new("UICorner", {CornerRadius = UDim.new(0, 6), Parent = tabButton})

        local tabText = new("TextLabel", {
            Name = "TabName",
            Size = UDim2.new(1, -20, 1, 0),
            Position = UDim2.new(0, 10, 0, 0),
            BackgroundTransparency = 1,
            Text = tabName,
            TextColor3 = Color3.fromRGB(255, 255, 255),
            TextSize = 14,
            Font = Enum.Font.GothamBold,
            TextXAlignment = Enum.TextXAlignment.Left,
            Parent = tabButton,
            ZIndex = 3
        })

        local contentFrame = new("Frame", {
            Name = tabName .. "Content",
            Size = UDim2.new(1, -170, 1, -50),
            Position = UDim2.new(0, 170, 0, 50),
            BackgroundColor3 = Color3.fromRGB(30, 30, 30),
            BackgroundTransparency = 0.7,
            BorderSizePixel = 0,
            Visible = false,
            Parent = frame,
            ZIndex = 1
        })

        new("UICorner", {CornerRadius = UDim.new(0, 6), Parent = contentFrame})

        tabButton.MouseButton1Click:Connect(function()
            if activeTab then
                activeTab.BackgroundTransparency = 0.7
                local oldContent = frame:FindFirstChild(activeTab.Name:gsub("Tab", "Content"))
                if oldContent then oldContent.Visible = false end
            end
            activeTab = tabButton
            tabButton.BackgroundTransparency = 0.5
            contentFrame.Visible = true
        end)

        return contentFrame
    end

    return api
end

return Breeze
