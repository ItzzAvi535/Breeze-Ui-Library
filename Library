local Breeze = {}

local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer
local gui = player:WaitForChild("PlayerGui")

-- Function to create a window
function Breeze:CreateWindow(titleText)
    local window = {}

    -- Create ScreenGui
    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "Breeze_" .. (titleText or "Untitled")
    screenGui.Parent = gui
    screenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling

    -- Create main frame
    local frame = Instance.new("Frame")
    frame.Name = "MainFrame"
    frame.Size = UDim2.new(0, 580, 0, 400)
    frame.Position = UDim2.new(0.5, -150, 0.5, -100)
    frame.AnchorPoint = Vector2.new(0.5, 0.5)
    frame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    frame.BackgroundTransparency = 0.4
    frame.BorderSizePixel = 0
    frame.Parent = screenGui
    frame.Active = true
    frame.Draggable = true

    -- Add corner rounding
    local uiCorner = Instance.new("UICorner")
    uiCorner.CornerRadius = UDim.new(0, 8)
    uiCorner.Parent = frame

    -- Add title text
    local title = Instance.new("TextLabel")
    title.Name = "Title"
    title.Size = UDim2.new(1, 0, 0, 40)
    title.Position = UDim2.new(0, 0, 0, 0)
    title.BackgroundTransparency = 1
    title.Text = titleText or "Breeze ui lib"
    title.TextColor3 = Color3.fromRGB(255, 255, 255)
    title.TextSize = 18
    title.Font = Enum.Font.GothamBold
    title.Parent = frame
    title.ZIndex = 2

    -- Add separator
    local separator = Instance.new("Frame")
    separator.Name = "Separator"
    separator.Size = UDim2.new(1, -20, 0, 1)
    separator.Position = UDim2.new(0, 10, 0, 40)
    separator.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    separator.BackgroundTransparency = 0.8
    separator.BorderSizePixel = 0
    separator.Parent = frame
    separator.ZIndex = 2

    -- Create tab button container
    local tabButtonContainer = Instance.new("Frame")
    tabButtonContainer.Name = "TabButtonContainer"
    tabButtonContainer.Size = UDim2.new(0, 150, 1, -50)
    tabButtonContainer.Position = UDim2.new(0, 10, 0, 50)
    tabButtonContainer.BackgroundTransparency = 1
    tabButtonContainer.Parent = frame
    tabButtonContainer.ZIndex = 3

    -- Add UIListLayout to tab button container
    local listLayout = Instance.new("UIListLayout")
    listLayout.SortOrder = Enum.SortOrder.LayoutOrder
    listLayout.Padding = UDim.new(0, 5)
    listLayout.Parent = tabButtonContainer

    -- Track active tab
    local activeTab = nil

    -- Add hover effect for main frame
    local function onHover(hovering)
        local targetTransparency = hovering and 0.3 or 0.4
        local tweenInfo = TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
        local tween = TweenService:Create(frame, tweenInfo, {BackgroundTransparency = targetTransparency})
        tween:Play()
    end

    frame.MouseEnter:Connect(function()
        onHover(true)
    end)

    frame.MouseLeave:Connect(function()
        onHover(false)
    end)

    -- Method to add a tab
    function window:AddTab(tabName)
        local tab = {}

        -- Create tab button
        local tabButton = Instance.new("TextButton")
        tabButton.Name = tabName .. "Tab"
        tabButton.Size = UDim2.new(1, -10, 0, 40)
        tabButton.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
        tabButton.BackgroundTransparency = 0.7
        tabButton.BorderSizePixel = 0
        tabButton.Text = ""
        tabButton.Parent = tabButtonContainer
        tabButton.ZIndex = 3
        tabButton.LayoutOrder = tabButton.LayoutOrder or 0

        -- Add corner rounding to tab button
        local tabCorner = Instance.new("UICorner")
        tabCorner.CornerRadius = UDim.new(0, 6)
        tabCorner.Parent = tabButton

        -- Create tab name text (aligned left)
        local tabText = Instance.new("TextLabel")
        tabText.Name = "TabName"
        tabText.Size = UDim2.new(1, -20, 1, 0)
        tabText.Position = UDim2.new(0, 10, 0, 0)
        tabText.BackgroundTransparency = 1
        tabText.Text = tabName
        tabText.TextColor3 = Color3.fromRGB(255, 255, 255)
        tabText.TextSize = 14
        tabText.Font = Enum.Font.GothamBold
        tabText.TextXAlignment = Enum.TextXAlignment.Left
        tabText.Parent = tabButton
        tabText.ZIndex = 3

        -- Create content frame (empty)
        local contentFrame = Instance.new("Frame")
        contentFrame.Name = tabName .. "Content"
        contentFrame.Size = UDim2.new(1, -170, 1, -50)
        contentFrame.Position = UDim2.new(0, 170, 0, 50)
        contentFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
        contentFrame.BackgroundTransparency = 0.7
        contentFrame.BorderSizePixel = 0
        contentFrame.Visible = false
        contentFrame.Parent = frame
        contentFrame.ZIndex = 1

        -- Add corner rounding to content
        local contentCorner = Instance.new("UICorner")
        contentCorner.CornerRadius = UDim.new(0, 6)
        contentCorner.Parent = contentFrame

        -- Tab click event for switching content
        tabButton.MouseButton1Click:Connect(function()
            if activeTab then
                activeTab.BackgroundTransparency = 0.7
                local oldContent = frame:FindFirstChild(activeTab.Name:gsub("Tab", "Content"))
                if oldContent then
                    oldContent.Visible = false
                end
            end
            activeTab = tabButton
            tabButton.BackgroundTransparency = 0.7 -- Keep transparency at 0.7
            contentFrame.Visible = true
        end)

        -- Add hover effect for tab button
        local function onTabHover(hovering)
            if tabButton ~= activeTab then
                local targetTransparency = hovering and 0.6 or 0.7
                local tweenInfo = TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
                local tween = TweenService:Create(tabButton, tweenInfo, {BackgroundTransparency = targetTransparency})
                tween:Play()
            end
        end

        tabButton.MouseEnter:Connect(function()
            onTabHover(true)
        end)

        tabButton.MouseLeave:Connect(function()
            onTabHover(false)
        end)

        -- Method to add a cool arrow button to this tab's content frame
        function tab:AddButton(buttonName, callback)
            local buttonContainer = Instance.new("TextButton")  -- The button container
            buttonContainer.Name = buttonName .. "Button"
            buttonContainer.Size = UDim2.new(1, -20, 0, 40)  -- Full width minus padding, 40px height
            buttonContainer.Position = UDim2.new(0, 10, 0, contentFrame:FindFirstChildOfClass("UIListLayout") and contentFrame:FindFirstChildOfClass("UIListLayout").AbsoluteContentSize.Y + 10 or 10)  -- Position below existing content or at top
            buttonContainer.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
            buttonContainer.BackgroundTransparency = 0.7
            buttonContainer.BorderSizePixel = 0
            buttonContainer.Text = ""
            buttonContainer.Parent = contentFrame
            buttonContainer.ZIndex = 1
            buttonContainer.AutoButtonColor = false  -- Disable default button color change

            -- Add corner rounding to button container
            local buttonCorner = Instance.new("UICorner")
            buttonCorner.CornerRadius = UDim.new(0, 6)
            buttonCorner.Parent = buttonContainer

            -- Button name text (left side)
            local buttonText = Instance.new("TextLabel")
            buttonText.Name = "ButtonText"
            buttonText.Size = UDim2.new(1, -40, 1, 0)  -- Full width minus arrow space
            buttonText.Position = UDim2.new(0, 10, 0, 0)  -- 10px padding from left
            buttonText.BackgroundTransparency = 1
            buttonText.Text = buttonName
            buttonText.TextColor3 = Color3.fromRGB(255, 255, 255)
            buttonText.TextSize = 14
            buttonText.Font = Enum.Font.GothamBold
            buttonText.TextXAlignment = Enum.TextXAlignment.Left
            buttonText.TextTruncate = Enum.TextTruncate.AtEnd
            buttonText.Parent = buttonContainer
            buttonText.ZIndex = 1

            -- Arrow image (right side)
            local arrowImage = Instance.new("ImageLabel")
            arrowImage.Name = "ArrowImage"
            arrowImage.Size = UDim2.new(0, 20, 0, 20)
            arrowImage.Position = UDim2.new(1, -30, 0.5, -10)  -- 10px from right, centered vertically
            arrowImage.BackgroundTransparency = 1
            arrowImage.Image = "rbxassetid://95681969022680"  -- Your arrow asset ID
            arrowImage.ImageColor3 = Color3.fromRGB(255, 255, 255)  -- White by default
            arrowImage.Parent = buttonContainer
            arrowImage.ZIndex = 1

            -- Hover effect for button (cool tint on arrow and transparency change)
            local function onButtonHover(hovering)
                local targetTransparency = hovering and 0.6 or 0.7
                local targetImageColor = hovering and Color3.fromRGB(100, 200, 255) or Color3.fromRGB(255, 255, 255)  -- Cool blue tint on hover
                local tweenInfo = TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
                TweenService:Create(buttonContainer, tweenInfo, {BackgroundTransparency = targetTransparency}):Play()
                TweenService:Create(arrowImage, tweenInfo, {ImageColor3 = targetImageColor}):Play()
            end

            buttonContainer.MouseEnter:Connect(function()
                onButtonHover(true)
            end)

            buttonContainer.MouseLeave:Connect(function()
                onButtonHover(false)
            end)

            -- Click effect (scale tween for press feel) and callback
            buttonContainer.MouseButton1Click:Connect(function()
                -- Press animation
                local pressTween = TweenService:Create(buttonContainer, TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut), {Size = UDim2.new(1, -20, 0, 38)})  -- Slightly smaller
                local releaseTween = TweenService:Create(buttonContainer, TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut), {Size = UDim2.new(1, -20, 0, 40)})  -- Back to normal
                pressTween:Play()
                pressTween.Completed:Connect(function()
                    releaseTween:Play()
                end)
                -- Fire callback if provided
                if callback then
                    callback()
                end
            end)

            -- Optional: Add UIListLayout to contentFrame if not exists (for stacking buttons)
            if not contentFrame:FindFirstChild("UIListLayout") then
                local contentListLayout = Instance.new("UIListLayout")
                contentListLayout.SortOrder = Enum.SortOrder.LayoutOrder
                contentListLayout.Padding = UDim.new(0, 10)
                contentListLayout.Parent = contentFrame
            end
            buttonContainer.LayoutOrder = #contentFrame:GetChildren()  -- Auto-order

            return buttonContainer  -- Return the button container for further customization
        end

        -- Return content frame for adding custom elements (if not using AddButton)
        tab.ContentFrame = contentFrame
        return tab
    end

    return window
end

return Breeze
