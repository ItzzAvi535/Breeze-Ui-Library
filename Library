local Breeze = {}

local Players = game:GetService("Players")

local function create(inst, props)
    local o = Instance.new(inst)
    for k, v in pairs(props) do
        o[k] = v
    end
    return o
end

function Breeze:CreateWindow(title, opts)
    opts = opts or {}
    local size = opts.size or UDim2.new(0, 500, 0, 300)
    local position = opts.position or UDim2.new(0.5, -250, 0.4, -150)
    local parent = opts.parent or Players.LocalPlayer:WaitForChild("PlayerGui")

    local screen = create("ScreenGui", {
        Name = "BreezeUI",
        ResetOnSpawn = false,
        Parent = parent
    })

    local window = create("Frame", {
        Name = title or "Window",
        Size = size,
        Position = position,
        BackgroundColor3 = Color3.fromRGB(25, 25, 25),
        BackgroundTransparency = 0.8, -- transparent
        BorderSizePixel = 0,
        Parent = screen
    })

    local titleBar = create("TextLabel", {
        Text = title or "Breeze Window",
        Size = UDim2.new(1, 0, 0, 30),
        BackgroundTransparency = 1,
        TextColor3 = Color3.fromRGB(255, 255, 255),
        Font = Enum.Font.GothamBold,
        TextSize = 16,
        Parent = window
    })

    return window
end

return Breeze
