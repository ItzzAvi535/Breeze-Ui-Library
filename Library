            KnobCorner.Parent = SliderKnob
            
            local currentValue = config.default
            local dragging = false
            local function updateSlider(value)
                currentValue = math.clamp(value, config.min, config.max)
                local barWidth = SliderBar.AbsoluteSize.X
                local fillWidth = (currentValue - config.min) / (config.max - config.min) * barWidth
                SliderFill.Size = UDim2.new(0, fillWidth, 1, 0)
                SliderKnob.Position = UDim2.new(0, fillWidth - 5, 0, -5)
                ValueLabel.Text = tostring(math.floor(currentValue))
                if callback then
                    callback(currentValue)
                end
            end
            
            updateSlider(config.default)
            
            SliderKnob.MouseButton1Down:Connect(function()
                dragging = true
            end)
            
            SliderKnob.TouchTap:Connect(function(touchPos)
                dragging = true
                local barPos = SliderBar.AbsolutePosition
                local barSize = SliderBar.AbsoluteSize.X
                local relativePos = math.clamp(touchPos.Position.X - barPos.X, 0, barSize)
                local value = config.min + (relativePos / barSize) * (config.max - config.min)
                updateSlider(value)
            end)
            
            UserInputService.InputEnded:Connect(function(input)
                if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) and dragging then
                    dragging = false
                end
            end)
            
            RunService.RenderStepped:Connect(function()
                if dragging then
                    local mousePos = UserInputService:GetMouseLocation()
                    local barPos = SliderBar.AbsolutePosition
                    local barSize = SliderBar.AbsoluteSize.X
                    local relativePos = math.clamp(mousePos.X - barPos.X, 0, barSize)
                    local value = config.min + (relativePos / barSize) * (config.max - config.min)
                    updateSlider(value)
                end
            end)
            
            tab.ContentFrame.CanvasSize = UDim2.new(0, 0, 0, (#tab.ContentFrame:GetChildren() - 1) * 50)
            
            return {
                Set = function(value)
                    updateSlider(value)
                end
            }
        end
        
